<UserControl x:Class="QuikTracer.Vsix.QuickTracerWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel>

            <!-- TRACE NODES -->

            <ItemsControl ItemsSource="{Binding TraceNodes}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <StackPanel Margin="10">

                            <Button Click="TraceNode_Click"
                                    Padding="0"
                                    BorderThickness="0"
                                    MaxWidth="250"
                                    Background="Transparent"
                                    Cursor="Hand">

                                <Border Padding="12"
                                        CornerRadius="6"
                                        BorderThickness="1">

                                    <Border.Style>

                                        <Style TargetType="Border">

                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />

                                            <Setter Property="Background"
                                                    Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding IsError}"
                                                             Value="True">

                                                    <Setter Property="BorderBrush"
                                                            Value="Red" />

                                                    <Setter Property="Background"
                                                            Value="#33FF0000" />

                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>

                                    </Border.Style>

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                                </Border>

                            </Button>

                            <TextBlock Text="↓"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                        </StackPanel>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <!-- DETAILS PANEL -->

            <Border Margin="10"
                    Padding="12"
                    BorderThickness="1"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">

                <StackPanel>

                    <TextBlock Text="Selected Node"
                               FontWeight="Bold"
                               FontSize="18"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                    <TextBlock Text="{Binding SelectedNode.Name,
                                     StringFormat=Name: {0}}"
                               FontSize="16"
                               Margin="0,4"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                    <TextBlock Text="{Binding SelectedNode.FilePath,
                                     StringFormat=FilePath: {0}}"
                               Margin="0,4"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                    <TextBlock Text="{Binding SelectedNode.LineNumber,
                                     StringFormat=LineNumber: {0}}"
                               Margin="0,4"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                    <TextBlock Text="{Binding SelectedNode.Details,
                                     StringFormat=Details: {0}}"
                               TextWrapping="Wrap"
                               Margin="0,4"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>